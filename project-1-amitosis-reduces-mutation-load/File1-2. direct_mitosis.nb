Cell["Evolve to equilibrium", "Subsubsection",
 CellChangeTimes->{{3.7161160740518303`*^9, 3.716116075833522*^9}, {
  3.7161165925636797`*^9, 3.716116593458967*^9}, {3.716295057544591*^9, 
