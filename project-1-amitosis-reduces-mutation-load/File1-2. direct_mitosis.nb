896ba5b739d4"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["f", "k"], TraditionalForm]],ExpressionUUID->
  "ed8ebf3b-c22c-4f4a-b826-496e23bf2da4"],
 ", frequency of genotype with ",
 StyleBox["k",
  FontSlant->"Italic"],
 " mutations\n",
 Cell[BoxData[
  FormBox[
   OverscriptBox["w", "_"], TraditionalForm]],ExpressionUUID->
  "4daf01e3-b61e-471f-b78d-45d7f3756a89"],
 ", mean fitness\n",
 Cell[BoxData[
  FormBox[
   OverscriptBox["w", "^"], TraditionalForm]],ExpressionUUID->
  "b3894737-bd03-42e1-b148-203ab02ff74f"],
 ", mean fitness at equilibrium\n",
 Cell[BoxData[
  FormBox[
   OverscriptBox["k", "_"], TraditionalForm]],ExpressionUUID->
  "4d62e278-5d8c-4917-b7cb-268206117d6e"],
 ", mean number of mutations\n\[ScriptCapitalV], variance in the number of \
mutations\n\[ScriptCapitalS], third central moment (skewness) of the number \
of mutations\n",
 StyleBox["s",
  FontSlant->"Italic"],
 ", effect of a mutation if present in ",
 StyleBox["n",
  FontSlant->"Italic"],
 " copies (",
 StyleBox["s ",
  FontSlant->"Italic"],
 "< 0 if mutations are deleterious)\n",
 StyleBox["n",
  FontSlant->"Italic"],
 ", ploidy\n",
 StyleBox["u",
  FontSlant->"Italic"],
 ", mutation rate per locus (haploid)"
}], "Text",
 CellChangeTimes->{{3.716116610551786*^9, 3.716116632383016*^9}, {
