  3.7163188764821*^9, 3.716318897881707*^9}, {3.717949460399457*^9, 
  3.71794946128402*^9}, {3.7179513040491247`*^9, 3.7179513067374496`*^9}, {
  3.7180429261721373`*^9, 3.71804293850703*^9}, {3.7184546991706057`*^9, 
