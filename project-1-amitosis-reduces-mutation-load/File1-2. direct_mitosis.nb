Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"stab1", "=", 
  RowBox[{"Reduce", "[", 
   RowBox[{"Flatten", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "1"}], "<", 
         RowBox[{"eig1", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "<", "1"}], ",", 
        RowBox[{"{", 
