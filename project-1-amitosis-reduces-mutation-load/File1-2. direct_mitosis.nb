Cell[BoxData[
 RowBox[{
  RowBox[{"evol", "[", 
   RowBox[{"t_", ",", "x_", ",", "s_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{
        RowBox[{"Length", "[", "x", "]"}], "-", "1"}]}], ",", 
      RowBox[{"i", "=", "0"}], ",", 
      RowBox[{"y", "=", "x"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"i", "<", "t"}], ",", 
       RowBox[{
        RowBox[{"y", "=", 
         RowBox[{"iter", "[", 
          RowBox[{"y", ",", "s", ",", "u"}], "]"}]}], ";", 
        RowBox[{"i", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", "y"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.718446453756936*^9, 3.7184465331950274`*^9}, {
   3.718446625599083*^9, 3.7184466896875477`*^9}, {3.71844899206207*^9, 
