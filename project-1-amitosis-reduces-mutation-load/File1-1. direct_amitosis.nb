   RowBox[{"p", "[", 
    RowBox[{"x_", ",", "k_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"PDF", "[", 
    RowBox[{
     RowBox[{"HypergeometricDistribution", "[", 
      RowBox[{"n", ",", 
       RowBox[{"2", "k"}], ",", 
       RowBox[{"2", "n"}]}], "]"}], ",", "x"}], "]"}]}], 
  "\[IndentingNewLine]"}]], "Input",
