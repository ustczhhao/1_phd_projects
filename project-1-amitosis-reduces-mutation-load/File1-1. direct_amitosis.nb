Cell[TextData[{
 "The probability that an individual containing ",
 StyleBox["k",
  FontSlant->"Italic"],
 " mutant alleles and ",
 StyleBox["n",
  FontSlant->"Italic"],
 "\[Dash]",
 StyleBox["k ",
  FontSlant->"Italic"],
 "wildtype alleles will produce an offspring containing ",
 StyleBox["x",
  FontSlant->"Italic"],
 " mutant alleles is given by the hypergeometric distribution (Schensted \
1958). "
}], "Text",
 CellChangeTimes->{{3.716117791862075*^9, 3.716117849300467*^9}, {
  3.7161213133880444`*^9, 3.716121455237845*^9}, {3.716134630434085*^9, 
  3.716134644878354*^9}, {3.7163050016413116`*^9, 
