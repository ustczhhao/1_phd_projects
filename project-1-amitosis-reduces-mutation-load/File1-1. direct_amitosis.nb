a34649c541a5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"equil", "[", 
   RowBox[{"x_", ",", "s_", ",", "u_", ",", "\[Epsilon]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{
        RowBox[{"Length", "[", "x", "]"}], "-", "1"}]}], ",", 
      RowBox[{"t", "=", "0"}], ",", 
      RowBox[{"y", "=", "x"}], ",", 
      RowBox[{"nexty", "=", 
       RowBox[{"x", "+", "1"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"EuclideanDistance", "[", 
         RowBox[{"y", ",", "nexty"}], "]"}], ">", "\[Epsilon]"}], ",", 
       RowBox[{
        RowBox[{"y", "=", "nexty"}], ";", 
        RowBox[{"nexty", "=", 
         RowBox[{"iter", "[", 
          RowBox[{"y", ",", "s", ",", "u"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"t", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"{", 
       RowBox[{"n", ",", "s", ",", "u", ",", "t"}], "}"}], "]"}], ";", 
     "\[IndentingNewLine]", "nexty"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.7184535178783903`*^9, 3.718453544103229*^9}, {
