Cell[BoxData[
 TagBox[GridBox[{
    {"\[Piecewise]", GridBox[{
       {
        FractionBox[
         RowBox[{
          RowBox[{"Binomial", "[", 
           RowBox[{
            RowBox[{"2", " ", "k_"}], ",", "x_"}], "]"}], " ", 
          RowBox[{"Binomial", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"-", "2"}], " ", "k_"}], "+", 
             RowBox[{"2", " ", "n_"}]}], ",", 
            RowBox[{"n_", "-", "x_"}]}], "]"}]}], 
         RowBox[{"Binomial", "[", 
          RowBox[{
           RowBox[{"2", " ", "n_"}], ",", "n_"}], "]"}]], 
        RowBox[{
         RowBox[{"0", "\[LessEqual]", "x_", "\[LessEqual]", 
          RowBox[{"2", " ", "k_"}]}], "&&", 
         RowBox[{
          RowBox[{
           RowBox[{"2", " ", "k_"}], "-", "n_"}], "\[LessEqual]", "x_", 
          "\[LessEqual]", 
          RowBox[{"2", " ", "k_"}]}], "&&", 
         RowBox[{"0", "\[LessEqual]", "x_", "\[LessEqual]", "n_"}], "&&", 
         RowBox[{
          RowBox[{
           RowBox[{"2", " ", "k_"}], "-", "n_"}], "\[LessEqual]", "x_", 
          "\[LessEqual]", "n_"}]}]},
       {"0", 
        TagBox["True",
         "PiecewiseDefault",
