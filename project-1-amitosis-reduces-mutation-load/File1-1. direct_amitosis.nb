Notebook[{

Cell[CellGroupData[{
Cell["Amitosis", "Title",
 CellChangeTimes->{{3.7161160740518303`*^9, 3.716116075833522*^9}, {
  3.716304884497027*^9, 3.716304897567937*^9}, {3.7179387102166023`*^9, 
  3.71793871080267*^9}, {3.718561468246727*^9, 
  3.718561469479643*^9}},ExpressionUUID->"db7ece19-c5fd-43cb-9252-\
a8d6b6a8e928"],

Cell[TextData[{
 "We try to predict the change in the mean number of mutations at a single \
locus ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    OverscriptBox["k", "_"], ")"}], TraditionalForm]],ExpressionUUID->
  "8338e959-0c45-4d11-8912-00acbaaceff6"],
 " in a population as a result of selection, mutation and reproduction by \
mitosis.  We model the distribution directly."
}], "Text",
 CellChangeTimes->{{3.716134741750414*^9, 3.716134777594236*^9}, {
  3.7162948667586393`*^9, 3.716294896370572*^9}, {3.716725671135705*^9, 
  3.716725701363481*^9}, {3.717938717788834*^9, 3.717938766521224*^9}, {
  3.7179388479229317`*^9, 3.717938864890143*^9}, {3.718044639413011*^9, 
  3.718044641125987*^9}},ExpressionUUID->"82b5b8e0-c7f1-4d42-87bd-\
32ee323eaf9e"],

