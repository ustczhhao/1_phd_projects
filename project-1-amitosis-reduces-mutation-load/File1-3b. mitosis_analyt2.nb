  RowBox[{"eq", "[", 
   RowBox[{"n_", ",", "s_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{
     SubscriptBox["f", "k"], "\[Rule]", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "k"], 
      FractionBox[
       RowBox[{
        RowBox[{"Binomial", "[", 
         RowBox[{"n", ",", "k"}], "]"}], 
        SuperscriptBox["n", "k"], " ", 
        SuperscriptBox["u", "k"], " ", 
        SuperscriptBox[
         RowBox[{"(", 
