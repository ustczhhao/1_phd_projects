           RowBox[{"n", " ", "u"}], "+", 
           RowBox[{"n", " ", "s", " ", "u"}]}], ")"}], 
         RowBox[{"n", "-", "k"}]]}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"s", "+", 
          RowBox[{"n", " ", "s", " ", "u"}]}], ")"}], "n"]]}]}], ",", 
